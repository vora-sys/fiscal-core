                "--testdox"
            ],
            "cwd": "${workspaceRoot}"
        },
        {
            "name": "Launch currently open script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.start_with_request=yes"
            ],
            "env": {
                "FISCAL_CERT_PATH": "../certs/JOHNNATHAN VICTOR GONCALVES SABBA00980556236.pfx",
                "FISCAL_CERT_PASSWORD": "1234",
                "XDEBUG_MODE": "debug,develop",
                "XDEBUG_CONFIG": "client_port=${port}"
            }
        },
